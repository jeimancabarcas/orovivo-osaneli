{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/drop-fcf/browser",
  "rewrites": [
    { "source": "/api/bold-webhook", "destination": "/api/bold-webhook" },
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/drop-fcf/**"
    }
  }
}
